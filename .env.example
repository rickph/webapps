# ─── PH Hoops Environment Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.

PORT=3000
NODE_ENV=development

# ─── PostgreSQL (REQUIRED) ────────────────────────────────────────────────────
# Supabase:  postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# Railway:   postgresql://postgres:[PASSWORD]@[HOST].railway.app:5432/railway
# Local:     postgresql://postgres:password@localhost:5432/phhoops
DATABASE_URL=postgresql://postgres:password@localhost:5432/phhoops

# ─── Security (CHANGE THESE in production!) ───────────────────────────────────
SESSION_SECRET=phhoops-session-secret-change-me
JWT_SECRET=phhoops-jwt-secret-change-me

# ─── Future: PayMongo for GCash/Maya payments ─────────────────────────────────
# PAYMONGO_SECRET_KEY=sk_test_xxxx
# PAYMONGO_PUBLIC_KEY=pk_test_xxxx
